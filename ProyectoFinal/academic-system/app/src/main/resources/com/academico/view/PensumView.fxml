<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.academico.controller.PensumController"
      spacing="10" style="-fx-padding: 10;">
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Carrera:"/>
        <ComboBox fx:id="comboCarrera" prefWidth="350"/>
    </HBox>
    <Label text="Asignaturas del Pensum:"/>
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCodigo" text="Código" prefWidth="100"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="300"/>
        </columns>
    </TableView>
    <HBox spacing="10">
        <Button text="Agregar Asignatura" onAction="#agregarAsignatura"/>
        <Button text="Eliminar Asignatura" onAction="#eliminarAsignatura"/>
    </HBox>
</VBox>
