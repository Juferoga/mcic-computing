@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam handwritten false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  ArrowColor #1565C0
}

title Subsistema de Gestion de Estudiantes - Casos de Uso Detallados

left to right direction

actor "Administrador" as Admin #FFF8E1

rectangle "Subsistema de Estudiantes" {
    
    usecase "CU-02.1 Crear Estudiante" as CU02_1
    usecase "CU-02.2 Consultar Estudiantes" as CU02_2
    usecase "CU-02.3 Modificar Estudiante" as CU02_3
    usecase "CU-02.4 Eliminar Estudiante" as CU02_4
    
    usecase "Validar Documento Unico" as VAL01
    usecase "Validar Datos Requeridos" as VAL02
    usecase "Asociar a Carrera" as VAL03
    usecase "Confirmar Eliminacion" as VAL04
    
    CU02_1 .> VAL01 : <<include>>
    CU02_1 .> VAL02 : <<include>>
    CU02_1 .> VAL03 : <<include>>
    CU02_3 .> VAL02 : <<include>>
    CU02_4 .> VAL04 : <<include>>
    
}

Admin --> CU02_1
Admin --> CU02_2
Admin --> CU02_3
Admin --> CU02_4

@enduml
