@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam handwritten false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  ArrowColor #1565C0
}

title Subsistema de Gestion de Asignaturas - Casos de Uso Detallados

left to right direction

actor "Administrador" as Admin #FFF8E1

rectangle "Subsistema de Asignaturas" {
    
    usecase "CU-03.1 Crear Asignatura" as CU03_1
    usecase "CU-03.2 Consultar Asignaturas" as CU03_2
    usecase "CU-03.3 Modificar Asignatura" as CU03_3
    usecase "CU-03.4 Eliminar Asignatura" as CU03_4
    
    usecase "Validar Codigo Asignatura" as VAL01
    usecase "Validar Datos Requeridos" as VAL02
    usecase "Validar Creditos" as VAL03
    usecase "Confirmar Eliminacion" as VAL04
    
    CU03_1 .> VAL01 : <<include>>
    CU03_1 .> VAL02 : <<include>>
    CU03_1 .> VAL03 : <<include>>
    CU03_3 .> VAL02 : <<include>>
    CU03_4 .> VAL04 : <<include>>
    
}

Admin --> CU03_1
Admin --> CU03_2
Admin --> CU03_3
Admin --> CU03_4

@enduml
